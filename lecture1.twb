      <aliases enabled='yes' />
      <column caption='Actual_sales' datatype='real' name='[Calculation_0513489972547584]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity]* [Unit Price]' />
      </column>
      <column caption='Dis_price' datatype='real' name='[Calculation_0513489973301249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Discount]* [Calculation_0513489972547584]' />
      </column>
      <column caption='upper' datatype='string' name='[Calculation_0513489975959555]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='UPPER([Customer Name])' />
      </column>
      <column caption='lower' datatype='string' name='[Calculation_0513489976696837]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LOWER([Product Name])' />
      </column>
      <column caption='Calculation1' datatype='string' name='[Calculation_0513489977376774]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Category],3)' />
      </column>
      <column caption='right' datatype='string' name='[Calculation_0513489977614343]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT([Region],3)' />
      </column>
      <column caption='Split' datatype='string' name='[Calculation_0513489977757704]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='SPLIT([Product Name],&quot; &quot;,1)' />
      </column>
      <column caption='Year' datatype='integer' datatype-customized='true' name='[Calculation_0513489978593289]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Order Date])' />
      </column>
      <column caption='Month' datatype='integer' name='[Calculation_0513489978687498]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([Order Date])' />
      </column>
      <column caption='Day' datatype='integer' name='[Calculation_0513489978773515]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DAY([Order Date])' />
      </column>
      <column caption='DateName' datatype='string' name='[Calculation_0513489979363340]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&quot;month&quot;,[Order Date],&quot;Monday&quot;)' />
      </column>
      <column caption='DatePart' datatype='integer' name='[Calculation_0513489980227598]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&quot;month&quot;,[Order Date],&quot;Monday&quot;)' />
      </column>
      <column caption='If' datatype='string' name='[Calculation_0513489981329423]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 1000 THEN &quot;Good sales&quot;&#13;&#10;else &quot;Bad sales&quot;&#13;&#10;end' />
      </column>
      <column caption='if_esle' datatype='string' name='[Calculation_0513489982136336]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 10000 THEN &quot;Good&quot;&#13;&#10;ELSEIF [Sales] &gt;5000 THEN &quot;avg&quot;&#13;&#10;ELSE &quot;low&quot;&#13;&#10;END' />
      </column>
      <column caption='Case' datatype='string' name='[Calculation_0513489982894097]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Region] &#13;&#10;WHEN &quot;North&quot; THEN &quot;it is poor city&quot;&#13;&#10;WHEN  &quot;South&quot; THEN &quot;it is avg city&quot;&#13;&#10;WHEN  &quot;East&quot; THEN &quot;it is rich city&quot;&#13;&#10;WHEN  &quot;West&quot; THEN &quot;it is low city &quot;&#13;&#10;END' />
      </column>
      <column caption='AND' datatype='string' name='[Calculation_0513489984245778]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 10000 AND [Profit] &gt;1000&#13;&#10;THEN &quot;Good&quot;&#13;&#10;ELSEIF [Sales] &gt;5000 AND [Profit]&gt; 500&#13;&#10;THEN &quot; avg&quot;&#13;&#10;END' />
      </column>
      <column caption='OR' datatype='string' name='[Calculation_0513489984815123]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 10000 OR  [Profit] &gt;1000&#13;&#10;THEN &quot;Good&quot;&#13;&#10;ELSEIF [Sales] &gt;5000 OR  [Profit]&gt; 500&#13;&#10;THEN &quot; avg&quot;&#13;&#10;END' />
      </column>
      <column caption='min' datatype='real' name='[Calculation_0513489986404373]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Profit])' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
